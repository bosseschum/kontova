<div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden shadow-2xl shadow-black/40">
  <div class="flex items-center gap-2 px-4 py-3 bg-gray-800/60 border-b border-gray-800">
    <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
    <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
    <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
    <span class="ml-3 text-xs text-gray-500 font-mono bg-gray-900 border border-gray-700 rounded-md px-3 py-1 truncate">
      <%= url %>
    </span>
  </div>
  <div class="aspect-video flex flex-col items-center justify-center gap-3 text-gray-700">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <%= yield %>
    </svg>
    <span class="text-sm text-gray-600"><%= label %></span>
  </div>
</div>
