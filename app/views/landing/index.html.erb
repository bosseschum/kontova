<!DOCTYPE html>
<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Kontova – Kassenverwaltung für Vereine</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-950 text-white antialiased">

    <%# NAV %>
    <nav class="sticky top-0 z-50 bg-gray-950/80 backdrop-blur border-b border-gray-800">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <%= link_to root_path, class: "text-xl font-bold" do %>
          Kont<span class="text-blue-500">o</span>va
        <% end %>
        <ul class="flex items-center gap-6 text-sm text-gray-400">
          <li class="hidden md:block"><a href="#features" class="hover:text-white transition">Features</a></li>
          <li class="hidden md:block"><a href="#workflow" class="hover:text-white transition">So funktioniert's</a></li>
          <li class="hidden md:block"><a href="#pricing" class="hover:text-white transition">Preise</a></li>
          <li class="hidden md:block"><a href="#kontakt" class="hover:text-white transition">Kontakt</a></li>
          <li>
            <%= link_to "Einloggen →", new_member_session_path,
                  class: "bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg font-semibold transition" %>
          </li>
        </ul>
      </div>
    </nav>

    <% if notice %>
      <div class="max-w-6xl mx-auto px-6 mt-4">
        <div class="p-3 bg-green-700 rounded-lg text-center font-semibold"><%= notice %></div>
      </div>
    <% end %>

    <%# HERO %>
    <header class="max-w-6xl mx-auto px-6 pt-16 pb-20 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <div class="inline-flex items-center gap-2 text-xs uppercase tracking-widest text-blue-400 font-semibold bg-blue-500/10 border border-blue-500/20 rounded-full px-3 py-1">
          Kassenverwaltung für Vereine
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold leading-tight mt-6">
          Weniger Papierkram.<br>
          <span class="text-blue-400">Mehr Verein.</span>
        </h1>
        <p class="text-gray-400 text-lg mt-6 max-w-md">
          Kontova übernimmt die Buchhaltung – von der Getränkekasse bis zum automatischen
          Kontoabgleich. Für Kassenwarte, die lieber feiern als rechnen.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#kontakt"
             class="bg-blue-600 hover:bg-blue-500 px-6 py-3 rounded-xl font-semibold flex items-center gap-2 transition">
            Jetzt anfragen
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#features"
             class="bg-gray-900 hover:bg-gray-800 border border-gray-800 px-6 py-3 rounded-xl font-semibold flex items-center gap-2 transition">
            Features ansehen
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg>
          </a>
        </div>
      </div>

      <%= render layout: "browser_frame", locals: { url: "meinverein.kontova.de", label: "Screenshot: Kiosk-Ansicht" } do %>
        <rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M3 9h18M9 21V9"></path>
      <% end %>
    </header>

    <%# SOCIAL PROOF %>
    <div class="border-y border-gray-800 bg-gray-900/40">
      <p class="max-w-6xl mx-auto px-6 py-5 text-center text-gray-400 text-sm">
        ⭐ Bereits im Einsatz bei deutschen Verbindungen und Vereinen
      </p>
    </div>

    <%# FEATURES %>
    <section id="features" class="max-w-6xl mx-auto px-6 py-24">
      <div class="mb-16">
        <div class="text-xs uppercase tracking-widest text-blue-400 font-semibold mb-3">Features</div>
        <h2 class="text-3xl sm:text-4xl font-bold">Alles was ein Verein braucht</h2>
        <p class="text-gray-400 mt-4 max-w-2xl">
          Von der Getränkekasse bis zur automatischen Kontoabstimmung – Kontova deckt den
          kompletten Kassenalltag ab.
        </p>
      </div>

      <%# KIOSK %>
      <div class="grid lg:grid-cols-2 gap-10 items-center mb-20">
        <div>
          <h3 class="text-2xl font-bold mb-3">🍺 Kiosk</h3>
          <p class="text-gray-400 mb-6">
            Mitglieder buchen ihre Getränke selbst – per PIN, ohne Kassierer.
            Läuft auf jedem Gerät im Browser.
          </p>
          <%= render "feature_list", items: [
                "PIN-geschützter Zugang – kein Name öffentlich sichtbar",
                "Warenkorb mit automatischem Kastenpreis",
                "Mischkästen konfigurierbar",
                "GiroCode QR-Code + Zahlungsdaten zum Kopieren",
                "Gesponserte Buchungen für besondere Anlässe"
              ] %>
        </div>
        <%= render layout: "browser_frame", locals: { url: "meinverein.kontova.de/kiosk", label: "Screenshot: Getränkeauswahl" } do %>
          <path d="M8 2h8l1 7H7L8 2z"></path><path d="M7 9c0 5 2 9 5 9s5-4 5-9"></path>
        <% end %>
      </div>

      <%# KASSENWART %>
      <div class="grid lg:grid-cols-2 gap-10 items-center mb-20">
        <div class="lg:order-2">
          <h3 class="text-2xl font-bold mb-3">💰 Kassenwart-Dashboard</h3>
          <p class="text-gray-400 mb-6">
            Volle Übersicht über alle Mitglieder, Transaktionen und Anträge. Einzahlungen,
            Auslagen und Mitgliedsbeiträge – alles an einem Ort.
          </p>
          <%= render "feature_list", items: [
                "Mitgliederverwaltung mit Rollenmodell",
                "Transaktionshistorie pro Mitglied",
                "Automatischer Mitgliedsbeitrag per Cronjob",
                "Antragsbearbeitung mit Belegprüfung",
                "Automatischer Bankabgleich via GoCardless"
              ] %>
        </div>
        <div class="lg:order-1">
          <%= render layout: "browser_frame", locals: { url: "meinverein.kontova.de/treasurer", label: "Screenshot: Kassenwart-Dashboard" } do %>
            <rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M3 9h18M9 3v18"></path>
          <% end %>
        </div>
      </div>

      <%# MITGLIEDER %>
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <h3 class="text-2xl font-bold mb-3">👤 Mitgliederbereich</h3>
          <p class="text-gray-400 mb-6">
            Jedes Mitglied hat einen eigenen Bereich – mit Saldo, Transaktionshistorie und
            der Möglichkeit Auslagen einzureichen.
          </p>
          <%= render "feature_list", items: [
                "Eigener Saldo und Buchungshistorie",
                "Auslagenerstattung mit Belegupload",
                "E-Mail-Benachrichtigungen bei Entscheidungen",
                "PIN und Passwort selbst ändern",
                "Monatlicher Kontoauszug per E-Mail"
              ] %>
        </div>
        <%= render layout: "browser_frame", locals: { url: "meinverein.kontova.de/member_area", label: "Screenshot: Mitgliederbereich" } do %>
          <circle cx="12" cy="8" r="4"></circle><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"></path>
        <% end %>
      </div>

      <%# FEATURE CARDS %>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mt-20">
        <% [
          ["📦", "Inventurverwaltung", "Einkäufe erfassen, Inventur machen, Schwund analysieren. Mit Soll/Ist-Vergleich und Mischkästen."],
          ["🏢", "Multi-Tenancy", "Jeder Verein bekommt seine eigene Subdomain. Daten sind vollständig voneinander getrennt."],
          ["🔄", "Automatischer Bankabgleich", "GoCardless Open Banking gleicht Überweisungen automatisch mit Mitgliedern ab."],
          ["📧", "Automatische E-Mails", "Willkommensmail mit PIN, monatlicher Kontoauszug, Benachrichtigungen bei Anträgen."],
          ["🔐", "Datenschutz by Design", "Kein Name im Kiosk sichtbar. PIN-Zugang schützt die Privatsphäre der Mitglieder."],
          ["📱", "Überall nutzbar", "Läuft im Browser auf jedem Gerät – Smartphone, Tablet, Desktop. Keine App nötig."]
        ].each do |icon, title, text| %>
          <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 hover:border-gray-700 transition">
            <div class="text-3xl mb-4"><%= icon %></div>
            <h4 class="font-semibold text-lg mb-2"><%= title %></h4>
            <p class="text-gray-400 text-sm"><%= text %></p>
          </div>
        <% end %>
      </div>
    </section>

    <%# WORKFLOW %>
    <section id="workflow" class="bg-gray-900 border-y border-gray-800">
      <div class="max-w-6xl mx-auto px-6 py-24">
        <div class="text-xs uppercase tracking-widest text-blue-400 font-semibold mb-3">So funktioniert's</div>
        <h2 class="text-3xl sm:text-4xl font-bold">In vier Schritten startklar</h2>
        <p class="text-gray-400 mt-4 max-w-2xl">
          Kein kompliziertes Setup. Wir richten alles ein – du fängst sofort an.
        </p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-12">
          <% [
            ["✉️", "Anfragen", "Schreib uns kurz – wir richten deinen Verein ein."],
            ["⚙️", "Einrichten", "IBAN, Beiträge und Produkte konfigurieren."],
            ["👥", "Mitglieder einladen", "Jedes Mitglied bekommt automatisch eine Willkommensmail mit PIN."],
            ["🎉", "Loslegen", "Kiosk aufstellen, Beiträge laufen automatisch."]
          ].each_with_index do |(icon, title, text), i| %>
            <div class="bg-gray-950 border border-gray-800 rounded-2xl p-6">
              <div class="w-12 h-12 rounded-xl bg-blue-600/20 text-2xl flex items-center justify-center mb-4">
                <%= icon %>
              </div>
              <div class="text-xs font-mono text-gray-600 mb-1">0<%= i + 1 %></div>
              <h4 class="font-semibold mb-2"><%= title %></h4>
              <p class="text-gray-400 text-sm"><%= text %></p>
            </div>
          <% end %>
        </div>
      </div>
    </section>

    <%# PRICING %>
    <section id="pricing" class="max-w-6xl mx-auto px-6 py-24 text-center">
      <div class="text-xs uppercase tracking-widest text-blue-400 font-semibold mb-3">Preise</div>
      <h2 class="text-3xl sm:text-4xl font-bold">Transparent und fair</h2>
      <p class="text-gray-400 mt-4 max-w-xl mx-auto">
        Monatliche Gebühr pro Verein. Keine versteckten Kosten, keine Einrichtungsgebühr.
      </p>

      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto mt-12 text-left">
        <%# Starter %>
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 flex flex-col">
          <div class="text-sm uppercase tracking-widest text-gray-500 mb-4">Starter</div>
          <div class="text-4xl font-bold">
            15 €<span class="text-base text-gray-500 font-normal"> / Monat</span>
          </div>
          <ul class="space-y-3 mt-6 mb-8 text-gray-300 text-sm">
            <% ["Bis zu 30 Mitglieder", "Kiosk & Kassenwart-Dashboard", "Mitgliederbereich", "Automatische E-Mails", "E-Mail Support"].each do |feat| %>
              <li class="flex items-center gap-2"><span class="text-blue-400 font-bold">✓</span><%= feat %></li>
            <% end %>
          </ul>
          <a href="#kontakt"
             class="mt-auto block text-center bg-gray-800 hover:bg-gray-700 border border-gray-700 py-3 rounded-xl font-semibold transition">
            Anfragen
          </a>
        </div>

        <%# Vollständig (featured) %>
        <div class="bg-gray-900 border-2 border-blue-500 rounded-2xl p-8 flex flex-col relative">
          <span class="absolute -top-3 left-8 bg-blue-600 text-white text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full">
            Beliebt
          </span>
          <div class="text-sm uppercase tracking-widest text-blue-400 mb-4">Vollständig</div>
          <div class="text-4xl font-bold">
            25 €<span class="text-base text-gray-500 font-normal"> / Monat</span>
          </div>
          <ul class="space-y-3 mt-6 mb-8 text-gray-300 text-sm">
            <% ["Unbegrenzte Mitglieder", "Alle Starter-Features", "Automatischer Bankabgleich", "Inventurverwaltung", "Prioritäts-Support"].each do |feat| %>
              <li class="flex items-center gap-2"><span class="text-blue-400 font-bold">✓</span><%= feat %></li>
            <% end %>
          </ul>
          <a href="#kontakt"
             class="mt-auto block text-center bg-blue-600 hover:bg-blue-500 py-3 rounded-xl font-semibold transition">
            Anfragen
          </a>
        </div>
      </div>
    </section>

    <%# CONTACT & ADMIN LOGIN %>
    <section id="kontakt" class="bg-gray-900 border-t border-gray-800">
      <div class="max-w-6xl mx-auto px-6 py-24">
        <div class="text-xs uppercase tracking-widest text-blue-400 font-semibold mb-3">Kontakt</div>
        <h2 class="text-3xl sm:text-4xl font-bold mb-2">Interesse geweckt?</h2>
        <p class="text-gray-400 mb-12 max-w-xl">
          Schreib uns – wir melden uns innerhalb von 24 Stunden.
        </p>

        <div class="grid lg:grid-cols-2 gap-10">
          <%# CONTACT FORM %>
          <%= form_with url: landing_contact_path, method: :post, class: "space-y-4" do |f| %>
            <div>
              <%= f.label :name, "Name", class: "block text-gray-400 text-sm mb-1" %>
              <%= f.text_field :name, placeholder: "Max Mustermann", required: true,
                    class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 focus:outline-none focus:border-blue-500" %>
            </div>
            <div>
              <%= f.label :email, "E-Mail", class: "block text-gray-400 text-sm mb-1" %>
              <%= f.email_field :email, placeholder: "max@musterverein.de", required: true,
                    class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 focus:outline-none focus:border-blue-500" %>
            </div>
            <div>
              <%= f.label :message, "Nachricht", class: "block text-gray-400 text-sm mb-1" %>
              <%= f.text_area :message, rows: 5,
                    placeholder: "Kurze Beschreibung eures Vereins und wie viele Mitglieder ihr habt...",
                    required: true,
                    class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 focus:outline-none focus:border-blue-500" %>
            </div>
            <%= f.submit "Nachricht senden →",
                  class: "bg-blue-600 hover:bg-blue-500 px-6 py-3 rounded-xl font-semibold cursor-pointer transition" %>
          <% end %>

          <%# ADMIN LOGIN %>
          <div class="bg-gray-950 border border-gray-800 rounded-2xl p-8 h-fit">
            <h3 class="text-xl font-bold mb-2">Bereits Kunde?</h3>
            <p class="text-gray-400 mb-6">
              Melde dich in deinem Verein an oder wechsle direkt ins Super-Admin-Dashboard.
            </p>

            <%= link_to new_member_session_path,
                  class: "flex items-center justify-between bg-gray-800 hover:bg-gray-700 border border-gray-700 px-5 py-4 rounded-xl font-semibold mb-3 transition" do %>
              <span>🔑 Zum Vereins-Login</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            <% end %>

            <%= link_to super_admin_root_path,
                  class: "flex items-center justify-between bg-gray-800 hover:bg-gray-700 border border-gray-700 px-5 py-4 rounded-xl font-semibold transition" do %>
              <span>⚡ Super Admin</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            <% end %>

            <p class="text-gray-500 text-sm mt-6">
              Du weißt die URL deines Vereins?<br>
              Gehe direkt auf <strong class="text-gray-300">deinverein.kontova.de</strong>
            </p>
          </div>
        </div>
      </div>
    </section>

    <%# FOOTER %>
    <footer class="border-t border-gray-800">
      <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
        <span class="font-bold text-white">Kontova</span>
        <span>© 2026 Bosse Schumacher &nbsp;·&nbsp; <a href="#" class="hover:text-gray-300">Impressum</a> &nbsp;·&nbsp; <a href="#" class="hover:text-gray-300">Datenschutz</a></span>
        <a href="mailto:contact@kontova.de" class="hover:text-gray-300">contact@kontova.de</a>
      </div>
    </footer>

  </body>
</html>
