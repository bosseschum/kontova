<!DOCTYPE html>
<html>
  <head>
    <title>Vereinskasse – Mitgliederbereich</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="min-h-screen bg-gray-950 text-white">

    <nav class="bg-gray-900 border-b border-gray-800 px-6 py-4 flex gap-6 items-center">
      <span class="font-bold text-lg text-purple-400">Mein Konto</span>
      <%= link_to "🍺 Kiosk", kiosk_root_path,
        class: "text-gray-300 hover:text-white" %>
      <%= link_to "Übersicht", member_area_root_path,
        class: "text-gray-300 hover:text-white" %>
      <%= link_to "Anträge", member_area_requests_path,
        class: "text-gray-300 hover:text-white" %>
      <div class="ml-auto text-sm text-gray-500">
        <%= current_member.display_name %> &nbsp;|&nbsp;
        <%= link_to "Abmelden", destroy_member_session_path,
          data: { turbo_method: :delete },
          class: "text-red-400 hover:text-red-300" %>
      </div>
    </nav>

    <main class="p-6">
      <% if notice %>
        <div class="mb-4 p-3 bg-green-700 rounded-lg"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="mb-4 p-3 bg-red-700 rounded-lg"><%= alert %></div>
      <% end %>
      <%= yield %>
    </main>

  </body>
</html>
