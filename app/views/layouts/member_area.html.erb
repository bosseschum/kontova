<!DOCTYPE html>
<html>
  <head>
    <title>KONTOVA – Mitgliederbereich</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="min-h-screen bg-gray-950 text-white">

    <div class="bg-gray-800 border-b border-gray-700 px-6 py-2 flex items-center gap-3">
    <% if current_member.admin? %>
        <span class="text-xs text-gray-500 uppercase tracking-widest">Admin</span>
        <%= link_to "💰 Kassenwart", treasurer_root_path,
            class: "text-xs px-3 py-1 rounded-full bg-gray-700 hover:bg-gray-600 text-gray-300" %>
        <%= link_to "📦 Inventur", inventory_root_path,
            class: "text-xs px-3 py-1 rounded-full bg-gray-700 hover:bg-gray-600 text-gray-300" %>
        <%= link_to "🏠 Mitglied", member_area_root_path,
            class: "text-xs px-3 py-1 rounded-full bg-blue-600 text-white font-semibold" %>

    <% elsif current_member.treasurer?(current_organization) %>

        <%= link_to "💰 Kassenwart", treasurer_root_path,
            class: "text-xs px-3 py-1 rounded-full bg-gray-700 hover:bg-gray-600 text-white font-semibold" %>
        <%= link_to "🏠 Mitglied", member_area_root_path,
            class: "text-xs px-3 py-1 rounded-full bg-blue-600 text-white font-semibold" %>

    <% elsif current_member.inventory_manager?(current_organization) %>

        <%= link_to "📦 Inventur", inventory_root_path,
            class: "text-xs px-3 py-1 rounded-full bg-gray-700 hover:bg-gray-600 text-white font-semibold" %>
        <%= link_to "🏠 Mitglied", member_area_root_path,
            class: "text-xs px-3 py-1 rounded-full bg-blue-600 text-white font-semibold" %>
    <% end %>
    </div>

    <nav class="bg-gray-900 border-b border-gray-800 px-6 py-4 flex gap-6 items-center overflow-auto">
      <span class="font-bold text-lg text-purple-400"><%= current_organization.name || "Mein Konto" %></span>
      <%= link_to "Kiosk", kiosk_root_path,
        class: "text-gray-300 hover:text-white" %>
      <%= link_to "Übersicht", member_area_root_path,
        class: "text-gray-300 hover:text-white" %>
      <%= link_to "Anträge", member_area_requests_path,
        class: "text-gray-300 hover:text-white" %>
      <%= link_to "Profil", member_area_profile_path,
        class: "text-gray-300 hover:text-white" %>
      <div class="ml-auto text-sm text-gray-500">
        <%= current_member.display_name %> &nbsp;|&nbsp;
        <%= link_to "Abmelden", destroy_member_session_path,
          data: { turbo_method: :delete },
          class: "text-red-400 hover:text-red-300" %>
      </div>
    </nav>

    <main class="p-6">
      <% if notice %>
        <div class="mb-4 p-3 bg-green-700 rounded-lg"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="mb-4 p-3 bg-red-700 rounded-lg"><%= alert %></div>
      <% end %>
      <%= yield %>
    </main>

  </body>
</html>
