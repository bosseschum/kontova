<!DOCTYPE html>
<html>
  <head>
    <title>Vereinskasse – Login</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="min-h-screen bg-gray-950 text-white flex items-center justify-center">
    <div class="bg-gray-900 rounded-2xl p-8 w-full max-w-sm">
      <h1 class="text-2xl font-bold mb-6 text-center">🔒 Admin Login</h1>
      <% if alert %>
        <div class="mb-4 p-3 bg-red-700 rounded-lg text-sm"><%= alert %></div>
      <% end %>
      <%= yield %>
    </div>
  </body>
</html>
