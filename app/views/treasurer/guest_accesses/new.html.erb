<h1 class="text-2xl font-bold mb-6">Gastzugang erstellen</h1>

<div class="bg-gray-900 rounded-xl p-6 max-w-lg">
    <%= form_with model: [:treasurer, @guest] do |f| %>
    <div class="mb-4">
        <%= f.label :name, class: "block text-gray-400 text-sm mb-1" %>
        <%= f.text_field :name, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>
    <div class="mb-4">
        <%= f.label :email, class: "block text-gray-400 text-sm mb-1" %>
        <%= f.text_field :email, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>
    <div class="mb-4">
        <%= f.label :expires_at, class: "block text-gray-400 text-sm mb-1" %>
        <%= f.date_select :expires_at, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>
    <div class="mb-4">
        <%= f.submit "Zugang erstellen", class: "w-full bg-blue-600 hover:bg-blue-500 py-3 rounded-lg font-semibold cursor-pointer" %>
    </div>
    <% end %>
</div>
