<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Kontoumsätze</h1>
    <% if @connection %>
      <div class="flex items-center gap-3">
        <span class="text-xs text-gray-500">
          <%= @connection.bank_name %> · Consent bis <%= @connection.consent_expires_at&.strftime("%d.%m.%Y") %>
        </span>
        <%= button_to "Trennen", treasurer_bank_connection_path,
              method: :delete,
              data: { confirm: "Bankverbindung wirklich trennen?" },
              class: "text-xs px-3 py-1 bg-red-900 hover:bg-red-800 rounded-lg" %>
      </div>
    <% end %>
  </div>

  <% if @connection.nil? %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 text-center">
      <p class="text-gray-400 mb-4">Noch kein Bankkonto verbunden.</p>
      <%= link_to "Konto verbinden", new_treasurer_bank_connection_path,
            class: "bg-blue-600 hover:bg-blue-500 px-5 py-2 rounded-xl font-semibold" %>
    </div>

  <% elsif @transactions.empty? %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 text-center">
      <p class="text-gray-400">Keine Transaktionen gefunden.</p>
    </div>

  <% else %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
      <% @transactions.each do |txn| %>
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-800 last:border-0">
          <div>
            <p class="font-medium"><%= txn.description.presence || "—" %></p>
            <p class="text-xs text-gray-500">
              <%= txn.booked_at&.strftime("%d.%m.%Y") %>
              · <%= txn.bank_account.iban %>
            </p>
          </div>
          <span class="font-mono font-semibold <%= txn.credit? ? 'text-green-400' : 'text-red-400' %>">
            <%= txn.credit? ? "+" : "" %><%= format("%.2f", txn.amount) %> €
          </span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
