<div class="mb-6">
  <h1 class="text-2xl font-bold">
    <% if @member %>
      Transaktionen - <%= @member.display_name %>
    <% else %>
      Transaktionen
    <% end %>
  </h1>
  <% if @member %>
    <div class="flex gap-3 mb-4 mt-4">
      <%= link_to "Alle Transaktionen", treasurer_transactions_path,
        class: "px-3 py-1 rounded-lg text-sm #{params[:sponsored].blank? ? 'bg-blue-600' : 'bg-gray-700'}" %>
      <%= link_to "Gesponserte Transaktionen", treasurer_transactions_path(sponsored: "1"),
        class: "px-3 py-1 rounded-lg text-sm #{params[:sponsored] == "1" ? 'bg-blue-600' : 'bg-gray-700'}" %>
      <%= link_to "Neue Transaktion", new_treasurer_transaction_path,
        class: "bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded-lg text-sm font-semibold" %>
    </div>
  <% else %>
      <%= link_to "Neue Transaktion", new_treasurer_transaction_path,
        class: "bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded-lg text-sm font-semibold" %>
  <% end %>
</div>

<div class="bg-gray-900 rounded-xl overflow-auto">
  <table class="w-full">
    <thead class="bg-gray-800 text-gray-400 text-sm">
      <tr>
        <th class="text-left px-4 py-3">Datum</th>
        <th class="text-left px-4 py-3">Mitglied</th>
        <th class="text-left px-4 py-3">Typ</th>
        <th class="text-left px-4 py-3">Notiz</th>
        <th class="text-right px-4 py-3">Betrag</th>
        <th class="text-right px-4 py-3">Aktionen</th>
      </tr>
    </thead>
    <tbody>
      <% @transactions.each do |tx| %>
        <tr class="border-t border-gray-800 hover:border-gray-800/50 <%= tx.sponsored? ? 'opacity-60' : '' %>">
          <td class="px-4 py-3 text-gray-400 text-sm">
            <%= tx.created_at.strftime("%d.%m.%Y %H:%M") %>
          </td>
          <td class="px-4 py-3"><%= tx.member&.display_name || "Gelöschtes Mitglied" %></td>
          <td class="px-4 py-3 text-gray-400 text-sm">
            <%= { "drink_purchase" => "Getränk", "deposit" => "Einzahlung",
                  "expense_reimbursement" => "Auslage", "membership_fee" => "Beitrag"
                }[tx.kind] %>
          </td>
          <td class="px-4 py-3 text-gray-400 text-sm"><%= tx.note %></td>
          <td class="px-4 py-3 text-right font-mono
            <%= tx.amount_cents >= 0 ? 'text-green-400' : 'text-red-400' %>">
            <%= format("%+.2f", (tx.original_amount_cents || tx.amount_cents) / 100.0) %>€
            <% if tx.sponsored? %>
              <span class="text-xs text-gray-500 ml-1">(gesponsert)</span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-right flex justify-end gap-3">
            <%= link_to "Bearbeiten", edit_treasurer_transaction_path(tx),
                  class: "text-blue-400 hover:text-blue-300 text-sm" %>
            <%= button_to "Löschen", treasurer_transaction_path(tx), method: :delete,
                  data: { turbo_confirm: "Transaktion wirklich löschen?" },
                  class: "text-red-400 hover:text-red-300 text-sm bg-transparent border-0 cursor-pointer p-0" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
