<h1 class="text-2xl font-bold mb-6">Transaktion bearbeiten</h1>

<div class="bg-gray-900 rounded-xl p-6 max-w-lg">
  <%= form_with model: @transaction, url: treasurer_transaction_path(@transaction), method: :patch do |f| %>

    <div class="mb-4">
      <%= f.label :member_id, "Mitglied", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.select :member_id, @members.map { |m| [m.display_name, m.id] }, {},
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :kind, "Typ", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.select :kind,
            [["Einzahlung", "deposit"],
             ["Auslage (Erstattung)", "expense_reimbursement"],
             ["Mitgliedsbeitrag", "membership_fee"],
             ["Getränkekauf", "drink_purchase"]],
            {},
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :amount_cents, "Betrag (in Cent)", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.number_field :amount_cents,
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
      <p class="text-gray-500 text-xs mt-1">Positiv = Gutschrift, Negativ = Belastung</p>
    </div>

    <div class="mb-6">
      <%= f.label :note, "Notiz", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.text_field :note,
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>

    <%= f.submit "Speichern",
          class: "w-full bg-blue-600 hover:bg-blue-500 py-3 rounded-lg font-semibold cursor-pointer" %>
  <% end %>
</div>
