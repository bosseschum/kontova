<h1 class="text-2xl font-bold mb-6">Anträge</h1>

<div class="bg-gray-900 rounded-xl overflow-auto">
  <table class="w-full">
    <thead class="bg-gray-800 text-gray-400 text-sm">
      <tr>
        <th class="text-left px-4 py-3">Datum</th>
        <th class="text-left px-4 py-3">Mitglied</th>
        <th class="text-left px-4 py-3">Beschreibung</th>
        <th class="text-right px-4 py-3">Betrag</th>
        <th class="text-center px-4 py-3">Status</th>
        <th class="text-right px-4 py-3">Aktionen</th>
      </tr>
    </thead>
    <tbody>
      <% @requests.each do |req| %>
        <tr class="border-t border-gray-800 hover:bg-gray-800/50">
          <td class="px-4 py-3 text-gray-400 text-sm">
            <%= req.created_at.strftime("%d.%m.%Y") %>
          </td>
          <td class="px-4 py-3"><%= req.member.display_name %></td>
          <td class="px-4 py-3 text-gray-300"><%= req.description %></td>
          <td class="px-4 py-3 text-right font-mono">
            <%= req.amount_cents ? format("%.2f", req.amount_cents / 100.0) + " €" : "–" %>
          </td>
          <td class="px-4 py-3 text-center">
            <span class="px-2 py-1 rounded-lg text-xs font-semibold
              <%= req.pending? ? 'bg-yellow-700 text-yellow-200' :
                  req.approved? ? 'bg-green-700 text-green-200' :
                  'bg-red-700 text-red-200' %>">
              <%= { "pending" => "Ausstehend", "approved" => "Genehmigt",
                    "rejected" => "Abgelehnt" }[req.status] %>
            </span>
          </td>
          <td class="px-4 py-3 text-right">
            <%= link_to "Details", treasurer_request_path(req),
                  class: "text-blue-400 hover:text-blue-300 text-sm" %>
          </td>
          <td class="px-4 py-3 text-right">
            <%= link_to "Löschen", treasurer_request_path(req), method: :delete,
                  data: { turbo_confirm: "Antrag wirklich löschen?" },
                  class: "text-red-400 hover:text-red-300 text-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
