<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold">Antrag von <%= @request.member.display_name %></h1>
  <%= link_to "Zurück", treasurer_requests_path,
        class: "bg-gray-700 hover:bg-gray-600 px-4 py-2 rounded-lg text-sm" %>
</div>

<div class="grid grid-cols-2 gap-6">
  <div class="bg-gray-900 rounded-xl p-6">
    <h2 class="text-lg font-semibold mb-4 text-gray-300">Details</h2>
    <dl class="space-y-3">
      <div>
        <dt class="text-gray-500 text-sm">Mitglied</dt>
        <dd class="text-white"><%= @request.member.display_name %></dd>
      </div>
      <div>
        <dt class="text-gray-500 text-sm">Art</dt>
        <dd class="text-white">
          <%= { "expense" => "Auslage", "other" => "Sonstiges" }[@request.kind] %>
        </dd>
      </div>
      <div>
        <dt class="text-gray-500 text-sm">Beschreibung</dt>
        <dd class="text-white"><%= @request.description %></dd>
      </div>
      <div>
        <dt class="text-gray-500 text-sm">Betrag</dt>
        <dd class="text-white font-mono">
          <%= @request.amount_cents ? format("%.2f", @request.amount_cents / 100.0) + " €" : "–" %>
        </dd>
      </div>
      <div>
        <dt class="text-gray-500 text-sm">Eingereicht am</dt>
        <dd class="text-white"><%= @request.created_at.strftime("%d.%m.%Y %H:%M") %></dd>
      </div>
    </dl>

    <% if @request.receipts.attached? %>
      <div class="mt-4">
        <p class="text-gray-500 text-sm mb-2">Belege</p>
        <ul class="space-y-1">
          <% @request.receipts.each_with_index do |receipt, index| %>
            <li>
              <%= link_to "Beleg #{index + 1} anzeigen", rails_blob_path(receipt, disposition: "inline"),
                    target: "_blank",
                    class: "text-blue-400 hover:text-blue-300 text-sm" %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>

  <% if @request.pending? %>
    <div class="bg-gray-900 rounded-xl p-6">
      <h2 class="text-lg font-semibold mb-4 text-gray-300">Entscheidung</h2>

      <%= button_to "✓ Genehmigen", approve_treasurer_request_path(@request),
            method: :post,
            class: "w-full bg-green-600 hover:bg-green-500 py-3 rounded-lg
                    font-semibold mb-3 cursor-pointer" %>

      <%= form_with url: reject_treasurer_request_path(@request), method: :post do |f| %>
        <%= f.text_area :note, placeholder: "Begründung (optional)",
              rows: 3,
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg
                      px-3 py-2 mb-3" %>
        <%= f.submit "✗ Ablehnen",
              class: "w-full bg-red-600 hover:bg-red-500 py-3 rounded-lg
                      font-semibold cursor-pointer" %>
      <% end %>
    </div>
  <% end %>
</div>
