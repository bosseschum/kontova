<h1 class="text-2xl font-bold mb-6">Übersicht</h1>

<div class="grid grid-cols-3 gap-4 mb-8">
  <div class="bg-gray-800 rounded-xl p-5">
    <p class="text-gray-400 text-sm">Mitglieder</p>
    <p class="text-3xl font-bold"><%= @members.count %></p>
  </div>
  <div class="bg-gray-800 rounded-xl p-5">
    <p class="text-gray-400 text-sm">Offene Schulden</p>
    <p class="text-3xl font-bold text-red-400"><%= format("%.2f", @members.sum(&:balance).then { |b| b < 0 ? b : 0 }) %>€</p>
  </div>
  <div class="bg-gray-800 rounded-xl p-5">
    <p class="text-gray-400 text-sm">Gesamtguthaben</p>
    <p class="text-3xl font-bold text-green-400"><%= format("%.2f", @members.sum(&:balance).then { |b| b > 0 ? b : 0 }) %>€</p>
  </div>
</div>

<h2 class="text-xl font-semibold mb-4">Mitgliedersalden</h2>
<div class="bg-gray-900 rounded-xl overflow-hidden">
  <table class="w-full">
    <thead class="bg-gray-800 text-gray-400 text-sm">
      <tr class="text-left px-4 py-3">Name</tr>
      <tr class="text-left px-4 py-3">Saldo</tr>
      <tr class="text-left px-4 py-3">Aktionen</tr>
    </thead>
    <tbody>
      <% @members.each do |member| %>
        <tr class="border-t border-gray-800 hover:bg-gray-800/50">
          <td class="px-4 py-3"><%= member.display_name %></td>
          <td class="px-4 py-3 text-right font-mono <%= member.balance >= 0 ? 'text-green-400' : 'text-red-400' %>"><%= format("%.2f", member.balance) %>€</td>
          <td class="px-4 py-3 text-right"><%= link_to "Transaktionen", new_treasurer_transaction_path(member_id: member.id), class: "text-blue-400 hover:text-blue-300 text-sm" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
