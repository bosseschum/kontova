<h1 class="text-2xl font-bold mb-6">Neues Mitglied</h1>

<div class="bg-gray-900 rounded-xl p-6 max-w-lg">
  <%= form_with model: @member, url: treasurer_members_path do |f| %>

    <div class="mb-4">
      <%= f.label :display_name, "Name", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.text_field :display_name, placeholder: "z.B. Max Mustermann",
        class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :email, "E-Mail", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.text_field :email,
        class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, "Passwort", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.password_field :password,
        class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
      <p class="text-gray-500 text-xs mt-1">
        Nur nötig für Kassenwart und Getränkewart
      </p>
    </div>

    <div class="mb-6">
      <%= f.label :pin, "PIN (4 Ziffern)", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.password_field :pin, maxlength: 4, placeholder: "****",
        class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2
                tracking-widest text-center text-lg" %>
    </div>

    <div class="mb-6">
      <%= f.label :role, "Rolle", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.select :role,
        [["Mitglied", "member"],
         ["Kassenwart", "treasurer"],
         ["Getränkewart", "inventory_manager"]], {},
        class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>
    <div class="mb-4 flex-col gap-2">
      <div class="flex items-center gap-3">
        <%= f.check_box :pays_fee, class: "w-4 h-4" %>
        <%= f.label :pays_fee, "Zahlt Aktivenbeitrag", class: "text-gray-300" %>
      </div>
      <div class="flex items-center gap-3">
        <%= f.check_box :lives_on_site, class: "w-4 h-4" %>
        <%= f.label :lives_on_site, "Zahlt Hausbewohnerbeitrag", class: "text-gray-300" %>
      </div>
    </div>
    <%= f.submit "Anlegen",
      class: "w-full bg-blue-600 hover:bg-blue-500 py-3 rounded-lg font-semibold cursor-pointer" %>
    <% end %>
</div>
