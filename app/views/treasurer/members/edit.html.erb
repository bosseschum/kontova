<h1 class="text-2xl font-bold mb-6">Mitglied bearbeiten</h1>

<div class="bg-gray-900 rounded-xl p-6 max-w-lg">
  <%= form_with model: @member, url: treasurer_member_path(@member), method: :patch do |f| %>
    <div class="mb-4">
      <%= f.label :display_name, "Name", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.text_field :display_name,
        class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :email, "E-Mail", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.email_field :email,
        class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, "Neues Passwort", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.password_field :password, placeholder: "Leer lassen um nicht zu ändern",
        class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>

    <%= f.fields_for :organization_membership, @membership do |mf| %>
      <div class="mb-6">
        <%= mf.label :pin, "PIN (4 Ziffern)", class: "block text-gray-400 text-sm mb-1" %>
        <%= mf.password_field :pin, maxlength: 4, placeholder: "****",
          class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2
                  tracking-widest text-center text-lg" %>
      </div>

      <div class="mb-6">
        <%= mf.label :role, "Rolle", class: "block text-gray-400 text-sm mb-1" %>
        <%= mf.select :role,
          [["Mitglied", "member"],
           ["Kassenwart", "treasurer"],
           ["Getränkewart", "inventory_manager"]],
        {},
        class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
      </div>

      <div class="mb-4 flex-col gap-2">
        <div class="flex items-center gap-3">
          <%= mf.check_box :pays_fee, class: "w-4 h-4" %>
          <%= mf.label :pays_fee, "Zahlt Aktivenbeitrag", class: "text-gray-300" %>
        </div>
        <div class="flex items-center gap-3">
          <%= mf.check_box :lives_on_site, class: "w-4 h-4" %>
          <%= mf.label :lives_on_site, "Zahlt Hausbewohnerbeitrag", class: "text-gray-300" %>
        </div>
      </div>
    <% end %>

    <div class="mb-4 flex flex-row gap-2">
      <%= f.submit "Speichern",
        class: "w-full bg-blue-600 hover:bg-blue-500 py-3 rounded-lg font-semibold cursor-pointer" %>
      <%= link_to "Abbrechen", treasurer_members_path,
        class: "w-full bg-gray-600 hover:bg-gray-500 py-3 rounded-lg font-semibold cursor-pointer text-center block" %>
    </div>
  <% end %>
</div>
