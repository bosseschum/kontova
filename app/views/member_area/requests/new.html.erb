<h1 class="text-2xl font-bold mb-6">Antrag stellen</h1>

<div class="bg-gray-900 rounded-xl p-6 max-w-lg">
  <%= form_with model: @request, url: member_area_requests_path do |f| %>

    <div class="mb-4">
      <%= f.label :kind, "Art des Antrags", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.select :kind,
            [["Auslagenerstattung", "expense"],
             ["Sonstiges", "other"]],
            {},
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :description, "Beschreibung", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.text_area :description, rows: 3, placeholder: "Was soll erstattet werden?",
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :amount_cents, "Betrag (in Cent)", class: "block text-gray-400 text-sm mb-1" %>
      <%= f.number_field :amount_cents, placeholder: "z.B. 1500 für 15,00 €",
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>

    <div class="mb-6" data-controller="file-upload">
      <%= f.label :receipts, "Belege (Foto/PDF)", class: "block text-gray-400 text-sm mb-1" %>

      <div class="bg-gray-800 border-2 border-dashed border-gray-600 rounded-lg p-4 text-center
                  hover:border-purple-500 transition-colors cursor-pointer"
           data-action="click->file-upload#openFilePicker">
        <%= f.file_field :receipts,
              multiple: true,
              accept: "image/*,application/pdf",
              data: { file_upload_target: "input", action: "change->file-upload#filesSelected" },
              class: "hidden" %>

        <div data-file-upload-target="noFiles">
          <p class="text-gray-400 text-sm">Klicke hier, um Belege auszuwählen</p>
          <p class="text-gray-600 text-xs mt-1">mehrere Dateien gleichzeitig auswählbar</p>
        </div>
      </div>

      <ul data-file-upload-target="list" class="mt-3 space-y-2"></ul>
    </div>

    <%= f.submit "Antrag einreichen",
          class: "w-full bg-purple-600 hover:bg-purple-500 py-3 rounded-lg
                  font-semibold cursor-pointer" %>
  <% end %>
</div>
