<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold">Mein Profil</h1>
  <%= link_to "Bearbeiten", edit_member_area_profile_path,
        class: "bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded-lg text-sm font-semibold" %>
</div>

<div class="bg-gray-900 rounded-xl p-6 max-w-lg">
  <dl class="space-y-4">
    <div>
      <dt class="text-gray-500 text-sm">Name</dt>
      <dd class="text-white mt-1"><%= current_member.display_name %></dd>
    </div>
    <div>
      <dt class="text-gray-500 text-sm">E-Mail</dt>
      <dd class="text-white mt-1"><%= current_member.email %></dd>
    </div>
    <div>
      <dt class="text-gray-500 text-sm">Kiosk-PIN</dt>
      <dd class="text-white mt-1 tracking-widest font-mono">••••</dd>
    </div>
  </dl>
</div>
