<div class="min-h-screen bg-gray-950 text-white p-6 flex flex-col items-center justify-center">

  <h1 class="text-2xl font-bold mb-2">Guthaben aufladen</h1>
  <p class="text-gray-400 mb-2"><%= @member.display_name %></p>
  <% if @member.balance < 0 %>
    <p class="text-3xl font-bold mb-8 text-red-400">
      <%= format("%.2f", @amount / 100.0).gsub(".", ",") %> € offen
    </p>
  <% else %>
    <p class="text-3xl font-bold mb-8 text-green-400">
      Keine Außenstände
    </p>
  <% end %>

  <%# ── Bank-Überweisung ── %>
  <% if @bank_qr %>
    <div class="w-full max-w-sm mb-10">
      <h2 class="text-lg font-semibold mb-4 text-gray-300 text-center">🏦 Überweisung</h2>

      <div class="flex justify-center mb-4">
        <div class="bg-white p-4 rounded-2xl">
          <%= @bank_qr.as_png(
              bit_depth: 1,
              border_modules: 4,
              color_mode: ChunkyPNG::COLOR_GRAYSCALE,
              color: "black",
              fill: "white",
              module_px_size: 6
          ).to_data_url.then { |url| image_tag url, class: "w-56 h-56" } %>
        </div>
      </div>
      <p class="text-gray-400 text-sm text-center mb-4">
        Mit Banking-App scannen für automatische Überweisung
      </p>

      <div class="bg-gray-900 rounded-xl p-5 space-y-3">
        <% if @member.balance < 0 %>

          <% [
            ["Empfänger",        "bank-name",      @bank_name],
            ["IBAN",             "bank-iban",       @bank_iban],
            ["Betrag",           "bank-amount",     "#{format("%.2f", @amount / 100.0).gsub(".", ",")} €"],
            ["Verwendungszweck", "bank-reference",  @reference]
            ].each do |label, id, value| %>
            <div class="flex justify-between items-center">
              <div>
                <p class="text-gray-500 text-xs"><%= label %></p>
                <p class="text-white text-sm font-mono" id="<%= id %>"><%= value %></p>
              </div>
              <button onclick="copyToClipboard('<%= id %>')"
                class="text-blue-400 hover:text-blue-300 text-sm px-3 py-1 bg-gray-800 rounded-lg">
                Kopieren
              </button>
            </div>
          <% end %>

        <% else %>

          <% [
                ["Empfänger",        "bank-name",      @bank_name],
                ["IBAN",             "bank-iban",       @bank_iban],
                ["Betrag",           "bank-amount",     ""],
                ["Verwendungszweck", "bank-reference",  "Spende #{@member.display_name}"]
                ].each do |label, id, value| %>
            <div class="flex justify-between items-center">
              <div>
                <p class="text-gray-500 text-xs"><%= label %></p>
                <p class="text-white text-sm font-mono" id="<%= id %>"><%= value %></p>
              </div>
              <button onclick="copyToClipboard('<%= id %>')"
                    class="text-blue-400 hover:text-blue-300 text-sm px-3 py-1 bg-gray-800 rounded-lg">
                Kopieren
              </button>
            </div>
          <% end %>

        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── PayPal ── %>
  <% if @paypal_qr %>
    <% if @bank_qr %>
      <div class="w-full max-w-sm border-t border-gray-800 mb-10"></div>
    <% end %>

    <div class="w-full max-w-sm mb-10">
      <h2 class="text-lg font-semibold mb-4 text-gray-300 text-center">💙 PayPal</h2>

      <div class="flex justify-center mb-4">
        <div class="bg-white p-4 rounded-2xl">
          <%= @paypal_qr.as_png(
              bit_depth: 1,
              border_modules: 4,
              color_mode: ChunkyPNG::COLOR_GRAYSCALE,
              color: "black",
              fill: "white",
              module_px_size: 6
          ).to_data_url.then { |url| image_tag url, class: "w-56 h-56" } %>
        </div>
      </div>
      <p class="text-gray-400 text-sm text-center mb-4">
        QR-Code scannen oder Link öffnen
      </p>

      <div class="bg-gray-900 rounded-xl p-5">
        <div class="flex justify-between items-center">
          <div>
            <p class="text-gray-500 text-xs">PayPal.me-Link</p>
            <p class="text-white text-sm font-mono" id="paypal-url"><%= @paypal_url %></p>
          </div>
          <button onclick="copyToClipboard('paypal-url')"
            class="text-blue-400 hover:text-blue-300 text-sm px-3 py-1 bg-gray-800 rounded-lg">
            Kopieren
          </button>
        </div>
      </div>
    </div>
  <% end %>

  <%# ── Fallback wenn nichts konfiguriert ── %>
  <% if @bank_qr.nil? && @paypal_qr.nil? %>
    <div class="bg-gray-900 rounded-xl p-6 w-full max-w-sm text-center">
      <p class="text-gray-400">Keine Zahlungsmethode konfiguriert.</p>
      <p class="text-gray-500 text-sm mt-2">Kassenwart bitte IBAN oder PayPal in den Einstellungen hinterlegen.</p>
    </div>
  <% end %>

  <%= link_to "Zurück", kiosk_root_path,
        class: "mt-6 bg-gray-700 hover:bg-gray-600 px-6 py-3 rounded-xl" %>

</div>

<script nonce="<%= request.content_security_policy_nonce %>">
  function copyToClipboard(elementId) {
  const text = document.getElementById(elementId).innerText;
  navigator.clipboard.writeText(text).then(() => {
  const btn = event.target;
  btn.innerText = "✓ Kopiert";
  btn.classList.add("text-green-400");
  setTimeout(() => {
  btn.innerText = "Kopieren";
  btn.classList.remove("text-green-400");
  }, 2000);
  });
  }
</script>
