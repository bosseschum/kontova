<%= turbo_frame_tag "kiosk" do %>
  <div class="min-h-screen bg-gray-950 text-white p-6">

    <%# Flash Messages %>
    <% if notice %>
      <div class="mb-4 p-4 bg-green-700 rounded-xl text-lg text-center font-semibold">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="mb-4 p-4 bg-red-700 rounded-xl text-lg text-center font-semibold">
        <%= alert %>
      </div>
    <% end %>

    <% if @selected_member && @pin_verified %>
      <%# Header %>
      <div class="mb-6 flex items-center justify-between">
        <div class="flex items-start gap-6">
          <div>
            <p class="text-gray-400 text-sm">Eingeloggt als</p>
            <p class="text-2xl font-bold"><%= @selected_member.display_name %></p>
            <% if @selected_member.role == "treasurer" %>
              <p class="text-sm font-semibold text-gray-400">(Hauptkassenwart)</p>
            <% elsif @selected_member.role == "inventory_manager" %>
              <p class="text-sm font-semibold text-gray-400">(Bierkassenwart)</p>
            <% end %>
            <p class="text-lg <%= @selected_member.balance >= 0 ? 'text-green-400' : 'text-red-400' %>">
              Saldo: <%= format("%.2f", @selected_member.balance) %> €
            </p>
          </div>
          <% if @selected_member.balance < 0 %>
            <div class="mt-4">
              <%= link_to "💳 Jetzt bezahlen", kiosk_payment_path(@selected_member, pin: params[:pin]),
                        data: { turbo_frame: "_top" },
                        class: "bg-emerald-600 hover:bg-emerald-500 px-4 py-2
                          rounded-xl text-sm font-semibold" %>
            </div>
          <% end %>
        </div>
        <%= link_to "Abbrechen", kiosk_root_path,
                  class: "bg-gray-700 hover:bg-gray-600 px-6 py-3 rounded-xl text-lg" %>
      </div>

      <%# Produkte %>
      <h2 class="text-xl font-semibold mb-4 text-gray-300">Getränk wählen</h2>
      <div class="mb-4 grid grid-cols-2 sm:grid-cols-2 gap-4">
        <% @products.each do |product| %>
          <% if product.has_crate? %>
            <div class="grid grid-cols-2 sm:grid-cols-2 gap-4">
              <%= form_tag add_to_cart_kiosk_drinks_path, method: :post do %>
                <%= hidden_field_tag :pin, params[:pin] %>
                <%= hidden_field_tag :product_id, product.id %>
                <%= hidden_field_tag :quantity, 1 %>
                <button type="submit" class="bg-blue-700 hover:bg-blue-600 active:scale-95
                transition rounded-2xl p-5 text-center w-full h-28
                flex flex-col items-center justify-center gap-1">
                  <p class="text-base font-bold leading-tight"><%= product.name %></p>
                  <p class="text-gray-300 text-sm"><%= format("%.2f", product.price) %> €</p>
                </button>
              <% end %>
              <%= form_tag add_to_cart_kiosk_drinks_path, method: :post do %>
                <%= hidden_field_tag :pin, params[:pin] %>
                <%= hidden_field_tag :product_id, product.id %>
                <%= hidden_field_tag :quantity, product.crate_size %>
                <button type="submit" class="bg-gray-600 hover:bg-gray-500 active:scale-95
                transition rounded-2xl p-5 text-center w-full h-28
                flex flex-col items-center justify-center gap-1">
                  <p class="text-base font-bold leading-tight">📦 <%= product.name %></p>
                  <p class="text-gray-400 text-xs"><%= product.crate_size %> Stk.</p>
                  <p class="text-gray-300 text-sm"><%= format("%.2f", product.crate_price) %> €</p>
                </button>
              <% end %>
            </div>
          <% else %>
            <%= form_tag add_to_cart_kiosk_drinks_path, method: :post do %>
              <%= hidden_field_tag :pin, params[:pin] %>
              <%= hidden_field_tag :product_id, product.id %>
              <%= hidden_field_tag :quantity, 1 %>
              <button type="submit" class="bg-blue-700 hover:bg-blue-600 active:scale-95
              transition rounded-2xl p-5 text-center w-full h-28
              flex flex-col items-center justify-center gap-1">
                <p class="text-base font-bold leading-tight"><%= product.name %></p>
                <p class="text-gray-300 text-sm"><%= format("%.2f", product.price) %> €</p>
              </button>
            <% end %>
          <% end %>
        <% end %>
      </div>

      <%# Warenkorb %>
      <% if @cart_items.any? %>
        <div class="mt-8 bg-gray-900 rounded-2xl p-6">
          <h2 class="text-xl font-semibold mb-4 text-gray-300">🛒 Warenkorb</h2>
          <div class="space-y-2 mb-4">
            <% @cart_items.each do |item| %>
              <% is_crate = item[:product].has_crate? && item[:quantity] == item[:product].crate_size %>
              <% item_total = is_crate ? item[:product].crate_price_cents : item[:product].price_cents * item[:quantity] %>
              <div class="flex items-center justify-between">
                <span class="text-gray-300">
                  <%= item[:quantity] %>x <%= item[:product].name %>
                  <% if is_crate %>
                    <span class="text-emerald-400 text-xs ml-1">(Kastenpreis)</span>
                  <% end %>
                </span>
                <div class="flex items-center gap-4">
                  <span class="font-mono text-gray-300">
                    <%= format("%.2f", item_total / 100.0) %>€
                  </span>
                  <%= form_tag remove_from_cart_kiosk_drinks_path, method: :post do %>
                    <%= hidden_field_tag :pin, params[:pin] %>
                    <%= hidden_field_tag :product_id, item[:product].id %>
                    <button type="submit" class="text-red-400 hover:text-red-300 text-sm">
                      ✕
                    </button>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <div class="border-t border-gray-700 pt-4 mb-6 flex justify-between items-center">
            <span class="text-lg font-semibold">Gesamt</span>
            <span class="text-2xl font-bold font-mono">
              <% if @is_mixed_crate %>

                <p class="text-emerald-400 text-sm mb-2">Kastenrabatt:
                  <%= (@cart_total - CRATE_PRICE_CENTS) / 100.0 %>€
                </p>
                <%= format("%.2f", CRATE_PRICE_CENTS / 100.0) %>

              <% else %>

                <%= format("%.2f", @cart_total / 100.0) %> €

              <% end %>
            </span>
          </div>

          <% if @total_quantity > 0 %>
            <p class="text-gray-500 text-sm mb-2">
              <%= @total_quantity %> / <%= CRATE_SIZE %> Flaschen -
              noch <%= CRATE_SIZE - @total_quantity %> bis zum Kastenpreis
            </p>
          <% end %>

          <div class="flex gap-3">
            <%= form_tag checkout_kiosk_drinks_path, method: :post do %>
              <%= hidden_field_tag :pin, params[:pin] %>
              <button type="submit"
                    class="flex-1 bg-emerald-600 hover:bg-emerald-500 px-6 py-4 rounded-xl
              font-bold text-lg active:scale-95 transition">
                ✓ Bezahlen
              </button>
            <% end %>
            <%= form_tag clear_cart_kiosk_drinks_path, method: :delete do %>
              <%= hidden_field_tag :pin, params[:pin] %>
              <button type="submit"
                    class="bg-gray-700 hover:bg-gray-600 px-6 py-4 rounded-xl
              font-semibold active:scale-95 transition">
                🗑 Leeren
              </button>
            <% end %>
          </div>
        </div>
      <% end %>

    <% else %>
      <div class="min-h-screen flex flex-col items-center justify-center">
        <h1 class="text-3xl font-bold mb-2 text-center"><%= current_organization.name %></h1>
        <p class="text-gray-400 text-center mb-8">Bitte PIN eingeben</p>

        <%= form_with url: kiosk_root_path, method: :get,
          data: { turbo: false } do |f| %>
          <%= f.password_field :pin,
            maxlength: 4,
            autofocus: true,
            class: "w-full text-center text-3xl tracking-widest bg-gray-800
                    border boder-gray-700 rounded-xl px-4 py-4 mb-4",
            placeholder: "****" %>
          <%= f.submit "Weiter",
            class: "w-full bg-blue-600 hover:bg-blue-500 py-3 rounded-xl
                    font-semibold cursor-pointer text-lg" %>
        <% end %>
        <div class="mt-8 text-center">
          <%= link_to new_member_session_path, data: { turbo: false },
            class: "bg-gray-800 hover:bg-gray-700 transition rounded-xl px-5 py-3
                    text-gray-300 hover:text-white text-sm inline-flex items-center gap-2" do %>
            <span>🔑 Mitgliederbereich</span>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>

<% end %>
