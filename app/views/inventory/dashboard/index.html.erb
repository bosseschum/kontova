<h1 class="text-2xl font-bold mb-6">Lagerübersicht</h1>

<div class="bg-gray-900 rounded-xl overflow-hidden">
  <table class="w-full">
    <thead class="bg-gray-800 text-gray-400 text-sm">
      <tr>
        <th class="text-left px-4 py-3">Produkt</th>
        <th class="text-right px-4 py-3">Eingekauft</th>
        <th class="text-right px-4 py-3">Verkauft</th>
        <th class="text-right px-4 py-3">Erwartet</th>
        <th class="text-right px-4 py-3">Gezählt</th>
        <th class="text-right px-4 py-3">Differenz</th>
      </tr>
    </thead>
    <tbody>
      <% @products.each do |product| %>
        <tr class="border-t border-gray-800 hover:bg-gray-800/50">
          <td class="px-4 py-3 font-medium"><%= product.name %></td>
          <td class="px-4 py-3 text-right text-gray-300"><%= product.total_purchased %></td>
          <td class="px-4 py-3 text-right text-gray-300"><%= product.total_sold %></td>
          <td class="px-4 py-3 text-right text-gray-300"><%= product.expected_stock %></td>
          <td class="px-4 py-3 text-right text-gray-300"><%= product.last_count&.actual_quantity || "-" %></td>
          <td class="px-4 py-3 text-right font-mono font-semibold">
            <%= product.stock_discrepancy.nil? ? 'text-gray-500' : 
              product.stock_discrepancy == 0 ? 'text-green-400' : 'text-red-400' %>
            <%= product.stock_discrepancy.nil? ? "-" : "%+d" % product.stock_discrepancy %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4 flex gap-3">
  <%= link_to "Neue Inventur", new_inventory_inventory_count_path, 
    class: "bg-emerald-600 hover:bg-emerald-500 px-4 py-2 rounded-lg text-sm font-semibold" %>
  <%= link_to "Einkauf erfassen", new_inventory_purchase_path,
    class: "bg-gray-700 hover:bg-gray-600 px-4 py-2 rounded-lg text-sm font-semibold" %>
</div>
