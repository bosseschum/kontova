<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold">Inventuren</h1>
  <%= link_to "Neue Inventur", new_inventory_inventory_count_path,
        class: "bg-emerald-600 hover:bg-emerald-500 px-4 py-2 rounded-lg text-sm font-semibold" %>
</div>

<div class="bg-gray-900 rounded-xl overflow-auto">
  <table class="w-full">
    <thead class="bg-gray-800 text-gray-400 text-sm">
      <tr>
        <th class="text-left px-4 py-3">Datum</th>
        <th class="text-left px-4 py-3">Produkt</th>
        <th class="text-right px-4 py-3">Erwartet</th>
        <th class="text-right px-4 py-3">Gezählt</th>
        <th class="text-right px-4 py-3">Differenz</th>
        <th class="text-left px-4 py-3">Erfasst von</th>
        <th class="text-left px-4 py-3">Aktionen</th>
      </tr>
    </thead>
    <tbody>
      <% @inventory_counts.each do |count| %>
        <tr class="border-t border-gray-800 hover:bg-gray-800/50">
          <td class="px-4 py-3 text-gray-400 text-sm">
            <%= count.counted_on.strftime("%d.%m.%Y") %>
          </td>
          <td class="px-4 py-3 font-medium"><%= count.product.name %></td>
          <td class="px-4 py-3 text-right"><%= count.product.expected_stock %></td>
          <td class="px-4 py-3 text-right"><%= count.actual_quantity %></td>
          <td class="px-4 py-3 text-right font-mono font-semibold
            <%= count.actual_quantity - count.product.expected_stock == 0 ? 'text-green-400' : 'text-red-400' %>">
            <%= "%+d" % (count.actual_quantity - count.product.expected_stock) %>
          </td>
          <td class="px-4 py-3 text-gray-400 text-sm"><%= count.member&.display_name || "Gelöschtes Mitglied" %></td>
          <td class="px-4 py-3 text-right flex justify-end gap-3">
            <%= button_to "Löschen",
                  inventory_inventory_count_path(count),
                  method: :delete,
                  data: { turbo_confirm: "Inventur wirklich löschen?" },
                  class: "text-red-400 hover:text-red-300 text-sm bg-transparent border-0 cursor-pointer p-0" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
