<h1 class="text-2xl font-bold mb-6">Gemischten Kasten anlegen</h1>

<div class="bg-gray-900 rounded-xl p-6 max-w-lg">
  <%= form_tag inventory_mixed_crates_path, method: :post do %>

    <div class="mb-4">
      <%= label_tag :name, "Name", class: "block text-gray-400 text-sm mb-1" %>
      <%= text_field_tag "mixed_crate[name]", nil, placeholder: "z.B. Biermischkasten",
                         class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>

    <div class="mb-6">
      <%= label_tag :price_cents, "Preis (in Cent)", class: "block text-gray-400 text-sm mb-1" %>
      <%= number_field_tag "mixed_crate[price_cents]", nil, placeholder: "z.B. 1500 für 15,00 €",
                           class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2" %>
    </div>

    <div class="mb-4 flex items-center gap-3">
      <%= check_box_tag "mixed_crate[active]", "1", true, class: "w-4 h-4" %>
      <%= label_tag :active, "Aktiv (im Kiosk sichtbar)", class: "text-gray-300" %>
    </div>

    <h2 class="text-lg font-semibold mb-3 mt-6 text-gray-300">Inhalt</h2>
    <% @products.each do |product| %>
      <div class="flex items-center gap-4 mb-2">
        <span class="text-gray-300 flex-1"><%= product.name %></span>
        <%= number_field_tag "items[#{product.id}]", 0, min: 0,
                             class: "w-20 bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-center" %>
        <span class="text-gray-500 text-sm">Stk.</span>
      </div>
    <% end %>

    <%= submit_tag "Anlegen",
                   class: "w-full bg-emerald-600 hover:bg-emerald-500 py-3 rounded-lg
                  font-semibold cursor-pointer mt-6" %>
  <% end %>
</div>